# Server
PORT=3333
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cs_agendamento?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=uploads
