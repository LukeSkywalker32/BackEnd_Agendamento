{
   "name": "sata_api",
   "version": "1.0.0",
   "description": "SATA - Sistema de Agendamentos de Transporte de Cargas",
   "main": "dist/server.js",
   "scripts": {
      "dev": "tsx watch src/server.ts",
      "build": "tsc",
      "start": "node dist/server.js",
      "lint": "biome lint ./src",
      "format": "biome format ./src --write",
      "check": "biome check ./src --write",
      "test": "vitest",
      "test:coverage": "vitest run --coverage"
   },
   "author": "Luke Skywalker",
   "license": "ISC",
   "private": false,
   "dependencies": {
      "bcrypt": "^6.0.0",
      "cors": "^2.8.6",
      "dotenv": "^17.4.0",
      "express": "^5.2.1",
      "helmet": "^8.1.0",
      "jsonwebtoken": "^9.0.3",
      "mongodb": "^7.1.1",
      "mongoose": "^9.4.1",
      "morgan": "^1.10.1",
      "multer": "^2.1.1",
      "zod": "^4.3.6"
   },
   "devDependencies": {
      "@biomejs/biome": "^2.4.12",
      "@types/bcrypt": "^6.0.0",
      "@types/cors": "^2.8.19",
      "@types/express": "^5.0.6",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/morgan": "^1.9.10",
      "@types/multer": "^2.1.0",
      "@types/node": "^25.5.2",
      "@types/supertest": "^7.2.0",
      "@vitest/coverage-v8": "^4.1.2",
      "mongodb-memory-server": "^11.0.1",
      "supertest": "^7.2.2",
      "tsx": "^4.21.0",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   }
}
